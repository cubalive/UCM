# Ignore everything by default
*

# Allow Dockerfile itself (needed for remote builds)
!Dockerfile

# Allow only what the Dockerfile needs
!package.json
!package-lock.json
!tsconfig.json
!vite.config.ts
!tailwind.config.ts
!postcss.config.js
!components.json
!script/
!server/
!client/
!shared/
!lib/
!attached_assets/
!migrations/
