modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["jq", "railway"]

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]
publicDir = "dist/public"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[userenv]

[userenv.shared]
PUBLIC_BASE_URL = "https://app.unitedcaremobility.com"
ALLOWED_ORIGIN_1 = "https://unitedcaremobility.lovable.app"
VITE_UCM_DEBUG = "true"
PUBLIC_BASE_URL_APP = "https://app.unitedcaremobility.com"
PUBLIC_BASE_URL_DRIVER = "https://driver.unitedcaremobility.com"
GEOFENCE_ENABLED = "true"
ETA_REFRESH_SECONDS = "20"
LOCATION_STALE_SECONDS = "180"
GEOFENCE_PICKUP_RADIUS_METERS = "120"
GEOFENCE_DROPOFF_RADIUS_METERS = "160"
SMS_REMINDER_ENABLED = "true"
SMS_T24_WINDOW_MINUTES = "20"
SMS_SCHEDULER_INTERVAL_SECONDS = "60"
PATIENT_LINK_TTL_HOURS = "72"
VITE_NATIVE_ENABLED = "false"
VITE_BG_TRACKING_ENABLED = "false"
DRIVER_V3_PERFORMANCE_ENABLED = "false"
DRIVER_V3_SMART_PROMPTS_ENABLED = "false"
DRIVER_V3_OFFLINE_OUTBOX_ENABLED = "false"
DRIVER_V3_SOUNDS_ENABLED = "false"
CLINIC_APP_URL = "https://clinic.unitedcaremobility.com"
DRIVER_APP_URL = "https://driver.unitedcaremobility.com"

[userenv.development]

[userenv.production]

[agent]
integrations = ["javascript_stripe:1.0.0"]
