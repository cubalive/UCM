{
  "name": "ucm-platform",
  "version": "1.0.0",
  "description": "United Care Mobility - NEMT dispatch, billing, and driver management platform",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed.ts",
    "seed:small": "tsx scripts/seed.ts small",
    "seed:full": "tsx scripts/seed.ts full"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@sentry/node": "^10.42.0",
    "@types/multer": "^2.1.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cron": "^3.1.0",
    "csrf-csrf": "^3.0.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.34.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.0",
    "stripe": "^17.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.26.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
