# UCM Environment Variables
# Copy to .env and fill in values

# ─── REQUIRED — server refuses to start without these ─────────────────────
# JWT signing key (min 32 chars): openssl rand -base64 48
JWT_SECRET=generate-with-openssl-rand-base64-64
# MUST be different from JWT_SECRET (min 32 chars): openssl rand -base64 48
JWT_REFRESH_SECRET=generate-with-openssl-rand-base64-64

# ─── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection (must point to Supabase; must include ?sslmode=require in production)
SUPABASE_DB_URL=postgresql://user:password@localhost:5432/ucm
# DATABASE_URL=  # fallback if SUPABASE_DB_URL not set
# Pool size across all replicas (default: 80). Per-replica = (global - 10) / replicas
DB_POOL_GLOBAL_MAX=80
# Optional: base64-encoded CA certificate for custom CAs (RDS, etc.)
# DB_SSL_CA=

# ─── Infrastructure ──────────────────────────────────────────────────────
# Redis for distributed rate limiting, job queue, caching
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Number of Railway replicas (for DB pool sizing). Default: 1
RAILWAY_REPLICA_COUNT=2
# Maximum WebSocket connections per replica (default: 500)
MAX_WS_CONNECTIONS=500

# ─── HIPAA / Security ────────────────────────────────────────────────────
# AES encryption key for PHI data
PHI_ENCRYPTION_KEY=
# Separate audit log file path (optional)
# PHI_AUDIT_LOG_PATH=

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── External Services ───────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RESEND_API_KEY=
# FCM_SERVICE_ACCOUNT=  # JSON string for Firebase push notifications

# ─── Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@ucm.example.com

# ─── App Config ──────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Optional ────────────────────────────────────────────────────────────
SENTRY_DSN=
CSRF_SECRET=your-csrf-secret-here
