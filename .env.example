# ==============================================
# UCM Platform - Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set for production.
# Variables marked [RECOMMENDED] should be set for full functionality.

# --- Core ---
NODE_ENV=development
PORT=5000

# --- Environment (Railway) ---
# UCM_ENV=                   # production | staging | development (overrides NODE_ENV for env detection)
# UCM_BUILD_VERSION=         # auto-set by build script

# --- Database [REQUIRED] (one required) ---
SUPABASE_DB_URL=
# DATABASE_URL=              # fallback if SUPABASE_DB_URL not set

# --- Auth [REQUIRED in production] ---
JWT_SECRET=
SESSION_SECRET=

# --- Supabase [REQUIRED] ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Seed Admin [REQUIRED for first boot] ---
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Google Maps [REQUIRED for routing/ETA] ---
GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_KEY=      # browser-side key (falls back to GOOGLE_MAPS_API_KEY)
# GOOGLE_MAPS_SERVER_KEY=     # server-only key (falls back to GOOGLE_MAPS_API_KEY)
# GOOGLE_MAPS_BROWSER_KEY=    # explicit browser key

# --- Stripe [REQUIRED for billing] ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PLATFORM_1200=

# --- Twilio SMS [RECOMMENDED] ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=         # outbound SMS number
# DISPATCH_PHONE_NUMBER=      # dispatch contact number shown to drivers

# --- Email / Resend [RECOMMENDED] ---
# RESEND_API_KEY=
# EMAIL_FROM=no-reply@unitedcaremobility.com
# EMAIL_FROM_NAME=United Care Mobility

# --- Redis / Upstash [RECOMMENDED] ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# REQUIRE_REDIS=false          # set true to fail fast if Redis unavailable

# --- Observability ---
# SENTRY_DSN=                  # Sentry error tracking DSN
# SENTRY_TRACES_SAMPLE_RATE=0.1
# LOG_LEVEL=info               # pino log level: debug, info, warn, error

# --- Firebase Push Notifications ---
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVICE_ACCOUNT_JSON=  # JSON string of Firebase service account

# --- Feature Flags ---
# GEOFENCE_ENABLED=false
# GEOFENCE_PICKUP_RADIUS_METERS=120
# GEOFENCE_DROPOFF_RADIUS_METERS=160
# GEOFENCE_FALLBACK_RADIUS_METERS=200
# GEOFENCE_ACCURACY_THRESHOLD_METERS=50
# SMS_REMINDER_ENABLED=false
# DRIVER_DEVICE_BINDING=false
# DISPATCH_WINDOW_ENABLED=false
# DLQ_ENABLED=false
# ALLOW_COMPLETED_EDIT=false

# --- Worker / Scheduler ---
# RUN_MODE=all                 # all | api | worker
# ORCHESTRATOR_POLL_MS=3000
# ROUTES_WORKER_POLL_MS=5000
# LEADER_ELECTION=true
# LEADER_LOCK_TTL_SECONDS=30
# JOB_PROCESSOR_INTERVAL_MS=5000
# MAX_JOBS_PER_TICK=10
# MAX_JOB_RUNTIME_MS=300000

# --- URLs [REQUIRED in production] ---
# PUBLIC_BASE_URL=https://app.unitedcaremobility.com
# PUBLIC_BASE_URL_APP=
# PUBLIC_BASE_URL_DRIVER=
# PUBLIC_BASE_URL_API=
# APP_PUBLIC_URL=              # alias for PUBLIC_BASE_URL

# --- CORS (dynamic origins, up to 10 each) ---
# ALLOWED_APP_ORIGIN_1=
# ALLOWED_PUBLIC_ORIGIN_1=

# --- WebSocket ---
# WS_MAX_CONNECTIONS=500

# --- Internal ---
# PAYROLL_INTERNAL_SECRET=     # internal auth for payroll APIs
# SMOKE_TEST_COMPANY_ID=       # company ID for smoke tests
# SUPPORT_EMAIL=support@unitedcaremobility.com
